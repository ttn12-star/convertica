#: utils_site/src/frontend/tool_configs/pdf_convert.py:708
msgid "Will the table formatting be preserved after conversion?"
msgstr "Czy formatowanie tabeli zostanie zachowane po konwersji?"

#: utils_site/src/frontend/tool_configs/pdf_convert.py:711
msgid ""

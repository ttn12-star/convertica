msgid "Position diagonal watermarks for document protection"
msgstr "Umieszczaj ukośne znaki wodne w celu ochrony dokumentu"

msgid "Use your company logo for professional branding"
msgstr "Używaj logo swojej firmy dla profesjonalnego brandingu"

msgid "Add 'CONFIDENTIAL' or 'DRAFT' text for document status"
msgstr ""

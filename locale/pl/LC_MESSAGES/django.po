msgstr ""
"Konwertuj dokumenty PDF na Markdown z zachowaną strukturą nagłówków i "
"formatowaniem tabel. Idealne do dokumentów, notatek i baz wiedzy."

msgid "Extract clean Markdown with heading hierarchy and table blocks"
msgstr "Wyodrębnij czysty Markdown z hierarchią nagłówków i blokami tabel"

msgid "PDF to Markdown Converter"
msgstr "Konwerter PDF na Markdown"

msgid "Convert PDF to Markdown"
msgstr "Konwertuj PDF na Markdown"

msgid "Heading hierarchy extraction"
msgstr "Ekstrakcja hierarchii nagłówków"


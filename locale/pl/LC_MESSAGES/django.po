msgstr[1] "%(quota)s wywołania API miesięcznie"
msgstr[2] "%(quota)s wywołań API miesięcznie"

msgid "Yearly"
msgstr "Rocznie"

msgid "Best value"
msgstr "Najlepsza wartość"

msgid "Lifetime"
msgstr "Dożywotni"

msgid "once"
msgstr "jednorazowo"


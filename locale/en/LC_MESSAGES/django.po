# ==================== flatten_pdf ====================
msgid "Flatten PDF Online Free - Remove Form Fields | Convertica"
msgstr "Flatten PDF Online Free - Remove Form Fields | Convertica"

msgid "Flatten PDF online free by removing interactive form fields, checkboxes, and annotations. Creates a static, non-editable PDF that preserves the original appearance. No registration required."
msgstr "Flatten PDF online free by removing interactive form fields, checkboxes, and annotations. Creates a static, non-editable PDF that preserves the original appearance. No registration required."

msgid "Remove interactive form fields and annotations from your PDF"
msgstr "Remove interactive form fields and annotations from your PDF"

msgid "Flatten PDF"
msgstr "Flatten PDF"

msgid "Remove Form Fields"
msgstr "Remove Form Fields"

msgid "Strips all interactive form fields, checkboxes, radio buttons, and text inputs"
msgstr "Strips all interactive form fields, checkboxes, radio buttons, and text inputs"

msgid "Appearance Preserved"
msgstr "Appearance Preserved"

msgid "Visual content stays identical - only interactive elements are removed"
msgstr "Visual content stays identical - only interactive elements are removed"

msgid "Remove Annotations"
msgstr "Remove Annotations"

msgid "Clears comments, highlights, sticky notes, and all other annotations"
msgstr "Clears comments, highlights, sticky notes, and all other annotations"

msgid "Fast flattening with immediate download"
msgstr "Fast flattening with immediate download"

msgid "What does flattening a PDF mean?"
msgstr "What does flattening a PDF mean?"

msgid "Flattening a PDF removes all interactive elements such as form fields, checkboxes, and annotations, converting them into static content. The PDF looks identical but can no longer be filled out or edited."
msgstr "Flattening a PDF removes all interactive elements such as form fields, checkboxes, and annotations, converting them into static content. The PDF looks identical but can no longer be filled out or edited."

msgid "Why would I need to flatten a PDF?"
msgstr "Why would I need to flatten a PDF?"

msgid "Flattening is useful when sharing forms that have been filled out, when you want to prevent further editing, or when sending a PDF to a printer or service that does not support interactive elements."
msgstr "Flattening is useful when sharing forms that have been filled out, when you want to prevent further editing, or when sending a PDF to a printer or service that does not support interactive elements."

msgid "Does flattening change the visual appearance?"
msgstr "Does flattening change the visual appearance?"

msgid "No. The visual appearance is preserved exactly. Text, images, and layout remain unchanged — only the interactive layer is removed."
msgstr "No. The visual appearance is preserved exactly. Text, images, and layout remain unchanged — only the interactive layer is removed."

msgid "Flatten PDF FAQ"
msgstr "Flatten PDF FAQ"

msgid "Fill out all form fields before flattening to lock in the entered values."
msgstr "Fill out all form fields before flattening to lock in the entered values."

msgid "Use flattening before printing to ensure all content renders correctly."
msgstr "Use flattening before printing to ensure all content renders correctly."

msgid "Flatten PDFs before sharing to prevent recipients from modifying form data."
msgstr "Flatten PDFs before sharing to prevent recipients from modifying form data."

msgid "Tips for Flattening PDFs"
msgstr "Tips for Flattening PDFs"

msgid "Flatten PDF to remove form fields and annotations"
msgstr "Flatten PDF to remove form fields and annotations"

msgid "<p><strong>Flatten PDF</strong> converts an interactive PDF into a static document by permanently embedding all form field values and removing annotation layers. The result is a clean, non-editable PDF that looks exactly like the original.</p><p>This is commonly needed when distributing completed forms, archiving documents, or preparing PDFs for printing where interactive elements may cause issues.</p>"
msgstr "<p><strong>Flatten PDF</strong> converts an interactive PDF into a static document by permanently embedding all form field values and removing annotation layers. The result is a clean, non-editable PDF that looks exactly like the original.</p><p>This is commonly needed when distributing completed forms, archiving documents, or preparing PDFs for printing where interactive elements may cause issues.</p>"

# ==================== sign_pdf ====================
msgid "Sign PDF Online Free - Add Signature to PDF | Convertica"
msgstr "Sign PDF Online Free - Add Signature to PDF | Convertica"

msgid "Add your signature to a PDF online free. Upload an image of your signature and place it anywhere on any page. No registration, no watermark. Works on Windows, Mac, Linux, iOS, Android."
msgstr "Add your signature to a PDF online free. Upload an image of your signature and place it anywhere on any page. No registration, no watermark. Works on Windows, Mac, Linux, iOS, Android."

msgid "Add your image signature to any PDF page"
msgstr "Add your image signature to any PDF page"

msgid "Sign PDF"
msgstr "Sign PDF"

msgid "Image Signature"
msgstr "Image Signature"

msgid "Upload any PNG or JPEG image of your handwritten signature and place it precisely on the PDF"
msgstr "Upload any PNG or JPEG image of your handwritten signature and place it precisely on the PDF"

msgid "Flexible Placement"
msgstr "Flexible Placement"

msgid "Choose the exact position and page for your signature, or apply it to all pages at once"
msgstr "Choose the exact position and page for your signature, or apply it to all pages at once"

msgid "Files are processed in-memory and deleted immediately — your signature is never stored"
msgstr "Files are processed in-memory and deleted immediately — your signature is never stored"

msgid "Signed PDF is ready for immediate download with no delays"
msgstr "Signed PDF is ready for immediate download with no delays"

msgid "What image formats are accepted for the signature?"
msgstr "What image formats are accepted for the signature?"

msgid "You can upload a PNG or JPEG image of your handwritten signature. PNG with a transparent background works best so the signature blends naturally into the PDF."
msgstr "You can upload a PNG or JPEG image of your handwritten signature. PNG with a transparent background works best so the signature blends naturally into the PDF."

msgid "Can I sign all pages at once?"
msgstr "Can I sign all pages at once?"

msgid "Yes. Enable the 'Apply to all pages' option and your signature will be stamped on every page of the PDF at the same position."
msgstr "Yes. Enable the 'Apply to all pages' option and your signature will be stamped on every page of the PDF at the same position."

msgid "Is this legally binding?"
msgstr "Is this legally binding?"

msgid "This tool adds a visual image signature to the PDF. For legally binding electronic signatures with audit trails and certificates, a dedicated e-signature service is recommended."
msgstr "This tool adds a visual image signature to the PDF. For legally binding electronic signatures with audit trails and certificates, a dedicated e-signature service is recommended."

msgid "Sign PDF FAQ"
msgstr "Sign PDF FAQ"

msgid "Use a PNG image with a transparent background for the cleanest signature result."
msgstr "Use a PNG image with a transparent background for the cleanest signature result."

msgid "Increase the signature width for large-format PDFs so it stays visible."
msgstr "Increase the signature width for large-format PDFs so it stays visible."

msgid "Use the 'Apply to all pages' option to stamp every page in a contract at once."
msgstr "Use the 'Apply to all pages' option to stamp every page in a contract at once."

msgid "Tips for Signing PDFs"
msgstr "Tips for Signing PDFs"

msgid "Add your signature to a PDF online"
msgstr "Add your signature to a PDF online"

msgid "<p><strong>Sign PDF</strong> lets you place a handwritten signature image directly onto any page of a PDF document. Upload your signature as a PNG or JPEG, choose the position and page, and download the signed PDF in seconds.</p><p>No account required. Files are processed securely and deleted immediately after download. The signed PDF retains all original content and formatting.</p>"
msgstr "<p><strong>Sign PDF</strong> lets you place a handwritten signature image directly onto any page of a PDF document. Upload your signature as a PNG or JPEG, choose the position and page, and download the signed PDF in seconds.</p><p>No account required. Files are processed securely and deleted immediately after download. The signed PDF retains all original content and formatting.</p>"


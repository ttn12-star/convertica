msgstr "Convert PNG to WebP for the best balance of quality and file size on the web."

msgid "Use PNG output when transparency must be preserved — it is the only lossless format that supports it (besides WebP)."
msgstr "Use PNG output when transparency must be preserved — it is the only lossless format that supports it (besides WebP)."

msgid "Convert to TIFF for archiving or print workflows that require the highest fidelity."
msgstr "Convert to TIFF for archiving or print workflows that require the highest fidelity."

msgid "Tips for Image Conversion"
msgstr "Tips for Image Conversion"

msgid "Convert images between formats online"
msgstr "Convert images between formats online"

msgid "<p><strong>Convert Image</strong> transforms your image files from one format to another instantly. Whether you need to convert a PNG to WebP for faster web loading, a BMP to JPEG to reduce file size, or a GIF to PNG for better quality, this tool handles it all.</p><p>No software installation required. All conversions happen on the server and your files are deleted immediately after download.</p>"
msgstr "<p><strong>Convert Image</strong> transforms your image files from one format to another instantly. Whether you need to convert a PNG to WebP for faster web loading, a BMP to JPEG to reduce file size, or a GIF to PNG for better quality, this tool handles it all.</p><p>No software installation required. All conversions happen on the server and your files are deleted immediately after download.</p>"

# ==================== pdf_to_text ====================
msgid "PDF to Text Converter Online Free | Convertica"
msgstr "PDF to Text Converter Online Free | Convertica"

msgid "Extract plain text from PDF online free. Convert PDF to TXT file instantly with optional page numbers and layout preservation. No registration required."
msgstr "Extract plain text from PDF online free. Convert PDF to TXT file instantly with optional page numbers and layout preservation. No registration required."

msgid "Extract plain text from your PDF in seconds"
msgstr "Extract plain text from your PDF in seconds"

msgid "PDF to Text Converter"
msgstr "PDF to Text Converter"

msgid "Extract Text"
msgstr "Extract Text"

msgid "Plain Text Output"
msgstr "Plain Text Output"

msgid "Extracts all text content from your PDF into a clean, portable .txt file"
msgstr "Extracts all text content from your PDF into a clean, portable .txt file"

msgid "Page Number Dividers"
msgstr "Page Number Dividers"

msgid "Optionally add page separators so you know where each page begins"
msgstr "Optionally add page separators so you know where each page begins"

msgid "Layout Preservation"
msgstr "Layout Preservation"

msgid "Option to preserve text positioning and column structure from the original"
msgstr "Option to preserve text positioning and column structure from the original"

msgid "Fast text extraction with immediate download"
msgstr "Fast text extraction with immediate download"

msgid "What text formats can be extracted from a PDF?"
msgstr "What text formats can be extracted from a PDF?"

msgid "All selectable text embedded in the PDF is extracted. Scanned PDFs or image-based PDFs without embedded text will produce empty or minimal output."
msgstr "All selectable text embedded in the PDF is extracted. Scanned PDFs or image-based PDFs without embedded text will produce empty or minimal output."

msgid "What does the 'preserve layout' option do?"
msgstr "What does the 'preserve layout' option do?"

msgid "When enabled, the extractor tries to maintain the original text positioning and column structure of the PDF. This can help with multi-column documents but may add extra whitespace."
msgstr "When enabled, the extractor tries to maintain the original text positioning and column structure of the PDF. This can help with multi-column documents but may add extra whitespace."

msgid "Will the output include images or tables?"
msgstr "Will the output include images or tables?"

msgid "No. Only plain text is extracted. Images are skipped, and table data is extracted as plain text rows without formatting."
msgstr "No. Only plain text is extracted. Images are skipped, and table data is extracted as plain text rows without formatting."

msgid "PDF to Text FAQ"
msgstr "PDF to Text FAQ"

msgid "Enable page numbers to easily navigate large extracted documents."
msgstr "Enable page numbers to easily navigate large extracted documents."

msgid "For multi-column PDFs, try enabling layout preservation for better results."
msgstr "For multi-column PDFs, try enabling layout preservation for better results."

msgid "Scanned PDFs require OCR before text extraction — use our PDF to Word tool for that."
msgstr "Scanned PDFs require OCR before text extraction — use our PDF to Word tool for that."

msgid "Tips for PDF Text Extraction"
msgstr "Tips for PDF Text Extraction"

msgid "Extract plain text from PDF files"
msgstr "Extract plain text from PDF files"

msgid "<p><strong>PDF to Text</strong> extraction pulls all embedded text from your PDF and saves it as a plain UTF-8 encoded .txt file. This is ideal for data processing, indexing, archiving, or feeding content into other tools.</p><p>Text-based PDFs extract cleanly and quickly. For scanned documents, consider running OCR first to generate selectable text before using this tool.</p>"
msgstr "<p><strong>PDF to Text</strong> extraction pulls all embedded text from your PDF and saves it as a plain UTF-8 encoded .txt file. This is ideal for data processing, indexing, archiving, or feeding content into other tools.</p><p>Text-based PDFs extract cleanly and quickly. For scanned documents, consider running OCR first to generate selectable text before using this tool.</p>"

msgstr "Convert Image"

msgid "6 Output Formats"
msgstr "6 Output Formats"

msgid "Convert to JPEG, PNG, WebP, GIF, BMP, or TIFF — all major image formats supported"
msgstr "Convert to JPEG, PNG, WebP, GIF, BMP, or TIFF — all major image formats supported"


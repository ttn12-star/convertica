msgstr "Reduce PDF file size without losing quality"

msgid "Reduce Up to 90%"
msgstr "Reduce Up to 90%"

msgid "Significantly reduce PDF file size while maintaining readable quality"
msgstr "Significantly reduce PDF file size while maintaining readable quality"

msgid "Perfect for Email"
msgstr "Perfect for Email"


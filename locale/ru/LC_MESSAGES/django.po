msgstr "Извлеките редактируемый текст из любого изображения за секунды"

msgid "Accurate OCR"
msgstr "Точный OCR"

msgid ""
"Adaptive preprocessing and confidence filtering for clean, readable text"
msgstr ""
"Адаптивная предобработка и фильтрация по достоверности для чистого, "
"читаемого текста"

msgid "17 Languages + Auto"
msgstr "17 языков + Авто"

msgid ""

msgid "Convert PDF documents to PowerPoint presentations"
msgstr "Конвертируйте документы ПДФ в презентации PowerPoint"

msgid "PDF to PowerPoint Converter"
msgstr "Конвертер ПДФ в PowerPoint"

msgid "Page-to-Slide Conversion"
msgstr "Конвертация страниц в слайды"


msgstr "اختر حجم الخط ونمطه وتنسيق الرقم ليتناسب مع مستندك"

msgid "Original PDF content and formatting remain unchanged"
msgstr "يظل محتوى وتنسيق PDF الأصلي دون تغيير"

msgid "Add page numbers instantly to any PDF document"
msgstr "أضف أرقام صفحات إلى مستندات PDF الخاصة بك."

msgid "How do I add page numbers to a PDF?"
msgstr "كيف يمكنني إضافة علامة مائية إلى PDF؟"

msgid ""

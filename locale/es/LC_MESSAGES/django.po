msgid "Extract editable text from any image in seconds"
msgstr "Extrae texto editable de cualquier imagen en segundos"

msgid "Accurate OCR"
msgstr "OCR Preciso"

msgid ""
"Adaptive preprocessing and confidence filtering for clean, readable text"
msgstr ""
"Preprocesamiento adaptativo y filtrado de confianza para texto limpio y "

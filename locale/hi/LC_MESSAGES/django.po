msgid "Page Number Dividers"
msgstr "पृष्ठ संख्या विभाजक"

msgid "Optionally add page separators so you know where each page begins"
msgstr ""
"वैकल्पिक रूप से पृष्ठ विभाजक जोड़ें ताकि आप जान सकें कि प्रत्येक पृष्ठ कहाँ "
"से शुरू होता है"

msgid "Layout Preservation"
msgstr "लेआउट संरक्षण"

msgid ""

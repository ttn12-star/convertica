msgstr "%(count)s भाषाएं"

msgid "No registration"
msgstr "पंजीकरण नहीं"

msgid "Files deleted instantly"
msgstr "फ़ाइलें तुरंत हटाई जाती हैं"

msgid "Most requested PDF tools at your fingertips"
msgstr "सबसे लोकप्रिय PDF टूल आपकी पहुँच में"


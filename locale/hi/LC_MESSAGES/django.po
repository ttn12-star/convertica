msgid "Convert PDF documents to HTML format"
msgstr "PDF दस्तावेज़ों को HTML प्रारूप में बदलें"

msgid "PDF to HTML Converter"
msgstr "PDF से HTML कन्वर्टर"

msgid "Clean HTML Output"
msgstr "स्वच्छ HTML आउटपुट"

msgid ""
"Convert your PDF to clean, well-structured HTML code. The output is ready "

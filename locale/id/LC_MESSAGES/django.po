msgstr "Hapus halaman yang tidak diinginkan dari dokumen PDF Anda."

msgid "Extract Pages"
msgstr "Ekstrak Halaman"

msgid "Extract specific pages from your PDF into a new file."
msgstr "Ekstrak halaman tertentu dari PDF Anda ke file baru."

msgid "Reorder and organize pages in your PDF document."
msgstr "Susun ulang dan atur halaman dalam dokumen PDF Anda."

msgid "Reduce PDF file size without losing quality."
msgstr "Kurangi ukuran file PDF tanpa kehilangan kualitas."

msgid "Protect and secure your PDF documents"
msgstr "Lindungi dan amankan dokumen PDF Anda"

msgid "Protect PDF"

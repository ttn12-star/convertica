msgid "EPUB to PDF"
msgstr "EPUB ke PDF"

msgid "Premium beta tool for converting eBooks to PDF format."
msgstr "Alat beta premium untuk mengonversi eBook ke format PDF."

msgid "PDF to EPUB"
msgstr "PDF ke EPUB"

msgid "Premium beta tool for converting PDFs to eReader-friendly EPUB."
msgstr "Alat beta premium untuk mengonversi PDF ke EPUB yang ramah eReader."

msgid "PDF to Markdown"
msgstr "PDF ke Word"

msgid ""
